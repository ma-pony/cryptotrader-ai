# 后端 API 基础地址（与 `arena serve` 默认端口对齐）
VITE_API_BASE_URL=http://localhost:8003

# X-API-Key（生产环境必填；dev 模式 FastAPI 默认放行可留空）
VITE_API_KEY=

# OpenTelemetry collector 端点（可选，用于前端 web vitals 上报）
VITE_OTLP_UI_ENDPOINT=

# Trace 查看器 URL 模板（可选）。设置后 decision-detail 页会显示 "OTel" 链接，
# 用 `{trace_id}` 作为占位符。例如：
#   Jaeger:  http://localhost:16686/trace/{trace_id}
#   Tempo:   http://localhost:3000/explore?queryType=traceId&traceId={trace_id}
# 留空则不显示链接。
VITE_TRACE_UI_URL=
