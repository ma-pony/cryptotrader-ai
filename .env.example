# ==============================================================================
# CryptoTrader AI — environment template
# ==============================================================================
# Three places API keys can live (loaded in this priority order):
#   1. environment variables  ← highest priority, what this file documents
#   2. config/local.toml      ← gitignored, currently the active source for
#                                fred/sosovalue/okx/llm keys in dev
#   3. config/default.toml    ← committed, all keys empty
#
# If a key is set in BOTH `.env` and `config/local.toml`, .env wins.
# Check `config/local.toml` first — keys likely already configured there.
# ==============================================================================


# ─── LLM API Keys (Required) ────────────────────────────────────────────────
# Get from each provider's dashboard. OpenAI + Anthropic are primary; others
# act as fallback via RunnableWithFallbacks (see config/local.toml `[llm]`).
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
KIMI_API_KEY=


# ─── Infrastructure ─────────────────────────────────────────────────────────
# Postgres + Redis run via docker compose. Override these only when pointing
# to a remote/cloud DB.
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptotrader
REDIS_URL=redis://localhost:6379/0
POSTGRES_USER=cryptotrader
POSTGRES_PASSWORD=


# ─── App + Models + Risk + Scheduler ────────────────────────────────────────
# These can stay on defaults from config/default.toml. Override only when
# you want a different model lineup or stricter risk limits.
APP_MODE=standalone
APP_ENGINE=paper

MODEL_ANALYSIS=gemini-3-flash
MODEL_DEBATE=gemini-3-flash
MODEL_VERDICT=gpt-5.4
MODEL_TECH_AGENT=gemini-3-flash
MODEL_CHAIN_AGENT=gemini-3.1-pro
MODEL_NEWS_AGENT=gemini-3.1-pro
MODEL_MACRO_AGENT=gemini-3.1-pro

DEBATE_MAX_ROUNDS=3
DEBATE_CONVERGENCE_THRESHOLD=0.1
DEBATE_DIVERGENCE_HOLD_THRESHOLD=0.7

DATA_DEFAULT_TIMEFRAME=1h
DATA_OHLCV_LIMIT=100

RISK_POSITION_MAX_SINGLE_PCT=0.10
RISK_POSITION_MAX_TOTAL_EXPOSURE_PCT=0.50
RISK_LOSS_MAX_DAILY_LOSS_PCT=0.03
RISK_LOSS_MAX_DRAWDOWN_PCT=0.10
RISK_LOSS_MAX_CVAR_95=0.05
RISK_COOLDOWN_SAME_PAIR_MINUTES=60
RISK_COOLDOWN_POST_LOSS_MINUTES=120
RISK_VOLATILITY_FLASH_CRASH_THRESHOLD=0.05
RISK_VOLATILITY_FUNDING_RATE_THRESHOLD=0.005
RISK_EXCHANGE_MAX_API_LATENCY_MS=2000
RISK_EXCHANGE_HEALTH_CHECK_INTERVAL_S=30
RISK_RATE_LIMIT_MAX_TRADES_PER_HOUR=6
RISK_RATE_LIMIT_MAX_TRADES_PER_DAY=20

SCHEDULER_ENABLED=false
SCHEDULER_PAIRS=["BTC/USDT","ETH/USDT"]
SCHEDULER_INTERVAL_MINUTES=240
SCHEDULER_EXCHANGE_ID=binance


# ==============================================================================
# Data Providers — drives the 4 agents' sufficiency signals
# ==============================================================================
# Without these, agents report `data_sufficiency=low` and contribute neutral
# 20% confidence to debate. With them populated, agents contribute meaningful
# direction at 50-80% confidence.
#
# ── Agent ↔ Provider mapping ─────────────────────────────────────────────────
#   tech_agent   : ccxt OHLCV (no key needed for public OHLCV)
#   chain_agent  : coinglass + cryptoquant + whale_alert
#   news_agent   : rss + coindesk (key optional, free tier OK)
#   macro_agent  : FRED + sosovalue + fear&greed + coingecko ← see below
# ==============================================================================


# ─── Macro data sources (macro_agent depends on these) ──────────────────────
#
# **FRED** — Federal Reserve Economic Data
#   Status:    REQUIRED for macro_agent sufficiency=high (fed_rate, DXY, VIX,
#              S&P500, 10y-2y yield curve, M2, CPI all sourced from here).
#   Free tier: 120 req/min, unlimited series. Free forever, just need email.
#   Get key:   https://fredaccount.stlouisfed.org/apikey
#   Currently  → ✅ set in config/local.toml
#
PROVIDER_FRED_API_KEY=
PROVIDER_FRED_ENABLED=true

# **Sosovalue** — Bitcoin/Ethereum ETF flow data
#   Status:    Recommended (etf_daily_net_inflow + etf_total_net_assets +
#              top per-ticker flows). Key macro signal — without it,
#              macro_agent loses visibility on ~$100B institutional flows.
#   Free tier: 1000 req/day on free plan after signup.
#   Get key:   https://sosovalue.com → 注册 → 开发者中心
#   Currently  → ✅ set in config/local.toml
#
PROVIDER_SOSOVALUE_API_KEY=
PROVIDER_SOSOVALUE_ENABLED=true

# Alternative.me Fear & Greed Index    — ✅ no key needed, free public endpoint
# CoinGecko BTC dominance              — ✅ no key needed, free public endpoint


# ─── On-chain providers (chain_agent depends on these) ──────────────────────
#
# **Coinglass** — funding rate / liquidations / OI / long-short ratio
#   Free tier: NO free tier as of 2024. ~$30/mo for basic.
#   Free alt:  Binance public derivatives API already integrated
#              (`PROVIDER_BINANCE_AUDIT_ENABLED=true` covers funding/OI).
#   Get key:   https://www.coinglass.com/
PROVIDER_COINGLASS_API_KEY=
PROVIDER_COINGLASS_ENABLED=true

# **CryptoQuant** — exchange netflows / on-chain whale tracking
#   Free tier: Limited daily series, requires signup.
#   Free alt:  Mempool.space + blockchain.com public APIs (no integration yet).
#   Get key:   https://cryptoquant.com/
#   Currently  → ✅ set in config/local.toml
PROVIDER_CRYPTOQUANT_API_KEY=
PROVIDER_CRYPTOQUANT_ENABLED=true

# **Whale Alert** — large transaction alerts
#   Free tier: 100 req/hr free
#   Get key:   https://whale-alert.io/
PROVIDER_WHALE_ALERT_API_KEY=
PROVIDER_WHALE_ALERT_ENABLED=true

# **DefiLlama** — TVL / DeFi metrics
#   Status:    ✅ no key needed, free public API
PROVIDER_DEFILLAMA_ENABLED=true

# **CoinGecko** — price / market cap / dominance
#   Status:    ✅ no key needed (free tier with rate limit)
PROVIDER_COINGECKO_ENABLED=true


# ─── News providers (news_agent depends on these) ───────────────────────────
#
# **CoinDesk** — premium crypto news API
#   Free tier: Limited. Free RSS feeds already integrated as fallback.
#   Currently  → ✅ set in config/local.toml
PROVIDER_COINDESK_API_KEY=


# ─── Exchange (live trading via OKX) ────────────────────────────────────────
#
# **OKX** — perpetual futures execution
#   Required:  to enable live trading. Without keys, system runs paper mode.
#   Get key:   https://www.okx.com/ → API management
#   Currently  → ✅ set in config/local.toml (sandbox=true for dry-run)
PROVIDER_OKX_API_KEY=
PROVIDER_OKX_SECRET_KEY=
PROVIDER_OKX_PASSPHRASE=
PROVIDER_OKX_ENABLED=false


# ─── Binance public APIs (no key needed) ────────────────────────────────────
PROVIDER_BINANCE_AUDIT_ENABLED=true
PROVIDER_BINANCE_SENTIMENT_ENABLED=true


# ─── Token Security ─────────────────────────────────────────────────────────
PROVIDER_ENFORCE_TOKEN_SECURITY=true
PROVIDER_MAX_ACCEPTABLE_RISK=MEDIUM


# ─── Notifications + API + Logging ──────────────────────────────────────────
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_ENABLED=true
NOTIFICATION_EVENTS=["trade","rejection","circuit_breaker","reconcile_mismatch","daily_summary"]

API_KEY=
AUTH_MODE=enabled
LOG_LEVEL=INFO
LOG_FORMAT=json


# ==============================================================================
# Free upstream data alternatives (no key, no integration yet — future work)
# ==============================================================================
# - **Yahoo Finance** (yfinance lib): VIX (^VIX), DXY (^DXY), 10y treasury (^TNX),
#   gold (GC=F), S&P500 (^GSPC). 15-min delayed, no key. Useful as FRED fallback.
# - **stooq.com**: Same metrics as above, daily resolution, CSV downloads.
# - **Mempool.space**: BTC fees / mempool / hashrate / difficulty. No key.
# - **Blockchain.com**: BTC hashrate / hodler stats. No key.
# - **CoinShares weekly flows**: Free PDF report (no API, would need scraping)
#   for ETF flow cross-check.
# - **CoinMarketCap**: Free tier 10k req/mo. Alternative to CoinGecko.
#
# To wire any of these in, create a new provider in
# `src/cryptotrader/data/providers/` following the `defillama.py` pattern
# (async httpx fetch, JSON parse, dataclass return).
