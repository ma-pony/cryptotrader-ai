# ============================================
# LLM API Keys (Required)
# ============================================
OPENAI_API_KEY=sk-xxx
ANTHROPIC_API_KEY=sk-ant-xxx

# ============================================
# Infrastructure (Optional - uses in-memory fallback)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/cryptotrader
REDIS_URL=redis://localhost:6379/0

# ============================================
# Application Settings
# ============================================
APP_MODE=standalone
APP_ENGINE=paper

# ============================================
# Model Configuration
# ============================================
MODEL_ANALYSIS=gpt-4o-mini
MODEL_DEBATE=gpt-4o-mini
MODEL_VERDICT=gpt-4o
MODEL_TECH_AGENT=gpt-4o-mini
MODEL_CHAIN_AGENT=gpt-4o-mini
MODEL_NEWS_AGENT=gpt-4o-mini
MODEL_MACRO_AGENT=gpt-4o-mini

# ============================================
# Debate Configuration
# ============================================
DEBATE_MAX_ROUNDS=3
DEBATE_CONVERGENCE_THRESHOLD=0.1
DEBATE_DIVERGENCE_HOLD_THRESHOLD=0.7

# ============================================
# Data Configuration
# ============================================
DATA_DEFAULT_TIMEFRAME=1h
DATA_OHLCV_LIMIT=100

# ============================================
# Risk Management - Position
# ============================================
RISK_POSITION_MAX_SINGLE_PCT=0.10
RISK_POSITION_MAX_TOTAL_EXPOSURE_PCT=0.50

# ============================================
# Risk Management - Loss Limits
# ============================================
RISK_LOSS_MAX_DAILY_LOSS_PCT=0.03
RISK_LOSS_MAX_DRAWDOWN_PCT=0.10
RISK_LOSS_MAX_CVAR_95=0.05

# ============================================
# Risk Management - Cooldown
# ============================================
RISK_COOLDOWN_SAME_PAIR_MINUTES=60
RISK_COOLDOWN_POST_LOSS_MINUTES=120

# ============================================
# Risk Management - Volatility
# ============================================
RISK_VOLATILITY_FLASH_CRASH_THRESHOLD=0.05
RISK_VOLATILITY_FUNDING_RATE_THRESHOLD=0.005

# ============================================
# Risk Management - Exchange Health
# ============================================
RISK_EXCHANGE_MAX_API_LATENCY_MS=2000
RISK_EXCHANGE_HEALTH_CHECK_INTERVAL_S=30

# ============================================
# Risk Management - Rate Limiting
# ============================================
RISK_RATE_LIMIT_MAX_TRADES_PER_HOUR=6
RISK_RATE_LIMIT_MAX_TRADES_PER_DAY=20

# ============================================
# Scheduler Configuration
# ============================================
SCHEDULER_ENABLED=false
SCHEDULER_PAIRS=["BTC/USDT","ETH/USDT"]
SCHEDULER_INTERVAL_MINUTES=240
SCHEDULER_EXCHANGE_ID=binance

# ============================================
# Data Providers (Optional - graceful degradation)
# ============================================
PROVIDER_COINGLASS_API_KEY=
PROVIDER_CRYPTOQUANT_API_KEY=
PROVIDER_WHALE_ALERT_API_KEY=
PROVIDER_FRED_API_KEY=
PROVIDER_COINGLASS_ENABLED=true
PROVIDER_CRYPTOQUANT_ENABLED=true
PROVIDER_WHALE_ALERT_ENABLED=true
PROVIDER_FRED_ENABLED=true
PROVIDER_DEFILLAMA_ENABLED=true
PROVIDER_COINGECKO_ENABLED=true

# OKX Skills (Optional)
PROVIDER_OKX_API_KEY=
PROVIDER_OKX_SECRET_KEY=
PROVIDER_OKX_PASSPHRASE=
PROVIDER_OKX_ENABLED=false

# Binance Skills
PROVIDER_BINANCE_AUDIT_ENABLED=true
PROVIDER_BINANCE_SENTIMENT_ENABLED=true

# Token Security
PROVIDER_ENFORCE_TOKEN_SECURITY=true
PROVIDER_MAX_ACCEPTABLE_RISK=MEDIUM

# ============================================
# Notifications (Optional)
# ============================================
NOTIFICATION_WEBHOOK_URL=
NOTIFICATION_ENABLED=true
NOTIFICATION_EVENTS=["trade","rejection","circuit_breaker","reconcile_mismatch","daily_summary"]

# ============================================
# Production Settings
# ============================================
API_KEY=
LOG_LEVEL=INFO
LOG_FORMAT=json
POSTGRES_USER=cryptotrader
POSTGRES_PASSWORD=
